        <IsA>library</IsA>
        <Summary>GraphicsMagick Image Processing System.</Summary>
        <Description>GraphicsMagick provides a set of CLI tools and APIs for manipulating, editing, and converting raster and vector images. GraphicsMagick is originally derived from ImageMagick 5.5.2 as of November 2002.</Description>
        <Archive sha1sum="cd71364d1736838811f399326b998d6653630b5f" type="tarxz">mirrors://sourceforge/graphicsmagick/GraphicsMagick-1.3.48.tar.xz</Archive>
        <BuildDependencies>
            <Dependency>xz-devel</Dependency>
            <Dependency>zlib-devel</Dependency>
            <Dependency>zstd-devel</Dependency>
            <Dependency>tiff-devel</Dependency>
            <Dependency>webp-devel</Dependency>
            <Dependency>lcms2-devel</Dependency>
            <Dependency>libSM-devel</Dependency>
            <Dependency versionFrom="0.2.15">libwmf-devel</Dependency>
            <Dependency>libzip-devel</Dependency>
            <Dependency>libjxl-devel</Dependency>
            <Dependency>libICE-devel</Dependency>
            <Dependency>jasper-devel</Dependency>
            <Dependency>libheif-devel</Dependency>
            <Dependency>libxml2-devel</Dependency>
            <Dependency>jbigkit-devel</Dependency>
            <Dependency>libXext-devel</Dependency>
            <Dependency>freetype-devel</Dependency>
            <Dependency>gperftools-devel</Dependency>
            <Dependency>ghostscript-devel</Dependency>
            <Dependency>libjpeg-turbo-devel</Dependency>          
        </BuildDependencies>
        <Patches>
